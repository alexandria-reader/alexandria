{
  "name": "@alexandria/backend",
  "version": "0.1.0",
  "description": "Learn languages by reading.",
  "main": "build/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/server.js",
    "dev": "cross-env NODE_ENV=development ts-node-dev src/server.ts",
    "staging": "cross-env NODE_ENV=staging ts-node-dev src/server.ts",
    "test": "cross-env NODE_ENV=test DATABASE_URL=postgresql://user:password@localhost:5432/test jest --verbose --runInBand --collectCoverage",
    "test:unit": "jest --config jest.unit.config.js --verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prettier": "npx prettier --write .",
    "format": "npm run prettier && npm run lint:fix",
    "tsc": "tsc",
    "start:test": "cross-env NODE_ENV=test DATABASE_URL=postgresql://user:password@localhost:5432/test node index.js"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "prettier --write --ignore-unknown",
      "git add"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandria-reader/backend.git"
  },
  "author": "Dana, Eamon, Marc",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alexandria-reader/backend/issues"
  },
  "homepage": "https://github.com/alexandria-reader/backend#readme",
  "dependencies": {
    "@alexandria/shared": "*",
    "@asteasolutions/zod-to-openapi": "8.4.1",
    "@hapi/boom": "^10.0.0",
    "article-parser": "^7.2.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.8.0",
    "pg-format": "^1.0.4",
    "resend": "^6.9.3",
    "swagger-ui-express": "5.0.1",
    "tslib": "^2.4.0",
    "typescript": "^5.9.3",
    "uuid": "11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@swc/core": "^1.15.17",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.6.5",
    "@types/pg-format": "^1.0.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.56.1"
  }
}
